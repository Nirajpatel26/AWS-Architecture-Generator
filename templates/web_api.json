{
  "name": "web_api",
  "description": "Serverless web API: API Gateway + Lambda + data store + auth",
  "core_services": ["api_gateway", "lambda", "dynamodb", "cognito", "cloudwatch"],
  "resources": [
    {
      "type": "aws_apigatewayv2_api",
      "name": "api",
      "args": {
        "name": "{{project_name}}-api",
        "protocol_type": "HTTP"
      }
    },
    {
      "type": "aws_lambda_function",
      "name": "handler",
      "args": {
        "function_name": "{{project_name}}-handler",
        "role": "aws_iam_role.lambda_exec.arn",
        "runtime": "${var.lambda_runtime}",
        "handler": "${var.lambda_handler}",
        "filename": "${var.lambda_filename}",
        "memory_size": "${var.lambda_memory_size}",
        "timeout": "${var.lambda_timeout}"
      }
    },
    {
      "type": "aws_iam_role",
      "name": "lambda_exec",
      "args": {
        "name": "{{project_name}}-lambda-exec",
        "assume_role_policy": "${jsonencode({Version = \"2012-10-17\", Statement = [{Effect = \"Allow\", Principal = {Service = \"lambda.amazonaws.com\"}, Action = \"sts:AssumeRole\"}]})}"
      }
    },
    {
      "type": "aws_dynamodb_table",
      "name": "data",
      "args": {
        "name": "{{project_name}}-data",
        "billing_mode": "PAY_PER_REQUEST",
        "hash_key": "id"
      },
      "slot": "data_store",
      "data_stores": ["nosql", "none"]
    },
    {
      "type": "aws_db_instance",
      "name": "data_sql",
      "args": {
        "identifier": "{{project_name}}-db",
        "engine": "postgres",
        "instance_class": "db.t3.micro",
        "allocated_storage": 20,
        "db_name": "appdb",
        "username": "appuser",
        "password": "${var.db_password}",
        "skip_final_snapshot": true
      },
      "slot": "data_store",
      "data_stores": ["sql"]
    },
    {
      "type": "aws_s3_bucket",
      "name": "data_object",
      "args": {"bucket": "{{project_name}}-data-object"},
      "slot": "data_store",
      "data_stores": ["object"]
    },
    {
      "type": "aws_cognito_user_pool",
      "name": "users",
      "args": {
        "name": "{{project_name}}-users"
      },
      "slot": "auth",
      "optional": true,
      "required_if": "auth_required"
    },
    {
      "type": "aws_cloudwatch_log_group",
      "name": "lambda_logs",
      "args": {
        "name": "/aws/lambda/{{project_name}}-handler",
        "retention_in_days": "${var.log_retention_days}"
      }
    }
  ],
  "variables": {
    "project_name": "webapi",
    "region": "us-east-1"
  }
}
